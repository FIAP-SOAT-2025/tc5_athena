{
  "title": "Athena - Saúde do Sistema",
  "uid": "athena-system",
  "schemaVersion": 36,
  "version": 2,
  "refresh": "5s",
  "time": { "from": "now-5m", "to": "now" },
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "API Status",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "up{job=\"kubernetes-pods\", app=\"tc5-athena-api\"}",
          "legendFormat": ""
        }
      ],
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red" },
                "1": { "text": "UP", "color": "green" }
              }
            }
          ]
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Pods Prontos",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "kube_deployment_status_replicas_ready{namespace=\"tc5-athena\", deployment=\"tc5-athena-api\"}",
          "legendFormat": ""
        }
      ],
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": []
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Total Requisições (1h)",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(increase(http_requests_total{namespace=\"tc5-athena\"}[1h]))",
          "legendFormat": ""
        }
      ],
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] },
          "mappings": []
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Restarts de Pods",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(kube_pod_container_status_restarts_total{namespace=\"tc5-athena\"})",
          "legendFormat": ""
        }
      ],
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "mappings": []
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 }
    },

    {
      "id": 10,
      "type": "row",
      "title": "Endpoints Mais Utilizados (24h)",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 4 }
    },
    {
      "id": 11,
      "type": "bargauge",
      "title": "Top Endpoints por Volume de Requisições",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "topk(7, sum by (route, method) (increase(http_requests_total{namespace=\"tc5-athena\"}[24h])))",
          "legendFormat": "{{method}} {{route}}"
        }
      ],
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "valueMode": "color",
        "showUnfilled": true,
        "minVizWidth": 0,
        "minVizHeight": 10
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "min": 0,
          "color": { "mode": "continuous-GrYlRd" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "mappings": []
        }
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 5 }
    },
    {
      "id": 12,
      "type": "bargauge",
      "title": "Top Endpoints com Mais Erros (4xx / 5xx)",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "topk(7, sum by (route, method) (increase(http_requests_total{namespace=\"tc5-athena\",status_code=~\"[45]..\"}[24h])))",
          "legendFormat": "{{method}} {{route}}"
        }
      ],
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "valueMode": "color",
        "showUnfilled": true,
        "minVizWidth": 0,
        "minVizHeight": 10
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "min": 0,
          "color": { "mode": "continuous-RdYlGr" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }] },
          "mappings": []
        }
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 5 }
    },

    {
      "id": 20,
      "type": "row",
      "title": "Atividade da API nas Últimas 24h",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 }
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Volume de Requisições por Endpoint",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (route, method) (rate(http_requests_total{namespace=\"tc5-athena\"}[10m]))",
          "legendFormat": "{{method}} {{route}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "min": 0 }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum", "max"] }
      },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 15 }
    },

    {
      "id": 30,
      "type": "row",
      "title": "Recursos do Container (Kubernetes)",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 }
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "CPU do Container (%)",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"tc5-athena\", container=\"tc5-athena-api\"}[5m])) * 100",
          "legendFormat": "CPU %"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0 }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 25 }
    },
    {
      "id": 32,
      "type": "timeseries",
      "title": "Memória do Container",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(container_memory_working_set_bytes{namespace=\"tc5-athena\", container=\"tc5-athena-api\"})",
          "legendFormat": "Memória"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes", "min": 0 }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 25 }
    }
  ]
}
